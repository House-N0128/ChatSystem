@{
    ViewData["Title"] = "登录";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">用户登录</h3>
                <div class="mb-3">
                    <label class="form-label">用户名</label>
                    <input type="text" id="username" class="form-control" placeholder="请输入用户名">
                </div>
                <div class="mb-3">
                    <label class="form-label">密码</label>
                    <input type="password" id="password" class="form-control" placeholder="请输入密码">
                </div>
                <div id="loginError" class="text-danger mb-2" style="display:none;"></div>
                <button class="btn btn-primary w-100" onclick="login()">登录</button>
                <p class="text-center mt-3 mb-0">
                    没有账号？<a href="/account/register">立即注册</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function login() {
    var username = document.getElementById('username').value.trim();
    var password = document.getElementById('password').value.trim();
    if (!username || !password) {
        showError('请填写用户名和密码');
        return;
    }
    var btn = document.querySelector('button');
    btn.disabled = true; btn.textContent = '登录中...';
    fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
    })
    .then(r => r.json())
    .then(data => {
        btn.disabled = false; btn.textContent = '登录';
        if (data.success) {
            // 保存token到cookie
            var d = new Date();
            d.setTime(d.getTime() + 24*60*60*1000);
            document.cookie = 'AuthToken=' + data.data.token + ';expires=' + d.toUTCString() + ';path=/';
            location.href = '/chat';
        } else {
            showError(data.message);
        }
    })
    .catch(e => { btn.disabled = false; btn.textContent = '登录'; showError('网络错误'); });
}

function showError(msg) {
    var el = document.getElementById('loginError');
    el.textContent = msg; el.style.display = 'block';
}
</script>
}
