@{
    ViewData["Title"] = "个人信息";
}
<link rel="stylesheet" href="~/css/chat.css" />

<div class="friends-page" style="max-width:500px">
    <h4 class="mb-3">⚙️ 个人信息</h4>

    <div class="card mb-3">
        <h6 class="mb-3">修改昵称</h6>
        <div class="mb-2"><strong>当前昵称：</strong><span id="currentNickname"></span></div>
        <div class="search-bar">
            <input type="text" id="nicknameInput" placeholder="输入新昵称">
            <button class="btn btn-primary" onclick="ChatApp.updateNickname()">保存</button>
        </div>
        <div id="nicknameResult" class="mt-2 small"></div>
    </div>

    <div class="card">
        <h6 class="mb-3">修改密码</h6>
        <div style="display:grid;gap:8px">
            <input type="password" id="oldPwdInput" class="form-control" placeholder="原密码">
            <input type="password" id="newPwdInput" class="form-control" placeholder="新密码（至少6位）">
            <button class="btn btn-primary" onclick="ChatApp.updatePassword()">修改密码</button>
        </div>
        <div id="pwdResult" class="mt-2 small"></div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat.js"></script>
    <script>ChatApp.initProfilePage();</script>
}
