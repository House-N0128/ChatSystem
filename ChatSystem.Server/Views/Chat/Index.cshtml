@{
    ViewData["Title"] = "聊天";
}
<link rel="stylesheet" href="~/css/chat.css" />

<!-- 标签页 -->
<ul class="nav nav-tabs mt-2" id="chatTabs">
    <li class="nav-item"><a class="nav-link active" id="tabPrivate" onclick="ChatApp.switchTab('private')">💬 私聊</a></li>
    <li class="nav-item"><a class="nav-link" id="tabGroup" onclick="ChatApp.switchTab('group')">👥 群聊</a></li>
</ul>

<div class="chat-wrapper">
    <!-- 左侧：联系人/群组列表 -->
    <div class="chat-sidebar" id="contactList"></div>

    <!-- 右侧：聊天区 -->
    <div class="chat-main">
        <div class="chat-header" id="chatHeader">
            <span class="title">👋 请选择好友或群组开始聊天</span>
        </div>
        <div class="chat-messages" id="messageList"></div>
        <div id="typingHint">对方正在输入...</div>
        <div class="chat-input" id="inputArea" style="display:none;">
            <button class="icon-btn" id="fileUploadBtn" title="发送文件" onclick="document.getElementById('fileInput').click()">📎</button>
            <input type="file" id="fileInput" style="display:none" onchange="ChatApp.uploadFile()">
            <button class="icon-btn" id="emojiBtn" title="表情" onclick="ChatApp.toggleEmoji()">😊</button>
            <input type="text" class="msg-text" id="msgInput" placeholder="输入消息... Shift+Enter 换行">
            <button class="send-btn btn btn-primary" onclick="ChatApp.sendMsg()">发送</button>
            <div class="emoji-popup" id="emojiPopup"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat.js"></script>
    <script>ChatApp.init();</script>
}
