@{
    ViewData["Title"] = "聊天";
}

<style>
    #chatContainer { display: flex; height: calc(100vh - 120px); margin-top: 10px; }
    #contactList { width: 260px; border-right: 1px solid #ddd; overflow-y: auto; padding: 10px; }
    #chatArea { flex: 1; display: flex; flex-direction: column; }
    #chatHeader { padding: 12px 16px; background: #f8f9fa; border-bottom: 1px solid #ddd; font-weight: bold; }
    #messageList { flex: 1; overflow-y: auto; padding: 16px; background: #f5f5f5; }
    #inputArea { display: flex; padding: 12px; border-top: 1px solid #ddd; background: #fff; }
    #inputArea input { flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 6px; margin-right: 10px; }
    #inputArea button { padding: 10px 24px; border-radius: 6px; }

    .contact-item { padding: 10px; cursor: pointer; border-radius: 6px; margin-bottom: 4px; display: flex; align-items: center; }
    .contact-item:hover { background: #e9ecef; }
    .contact-item.active { background: #0d6efd; color: #fff; }
    .contact-item .dot { width: 8px; height: 8px; border-radius: 50%; margin-right: 8px; }
    .contact-item .dot.online { background: #28a745; }
    .contact-item .dot.offline { background: #adb5bd; }

    .msg-bubble { max-width: 70%; margin-bottom: 12px; padding: 10px 14px; border-radius: 12px; word-wrap: break-word; }
    .msg-bubble.mine { background: #0d6efd; color: #fff; margin-left: auto; border-bottom-right-radius: 4px; }
    .msg-bubble.other { background: #fff; margin-right: auto; border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); }
    .msg-sender { font-size: 0.8rem; margin-bottom: 2px; opacity: 0.85; }
    .msg-time { font-size: 0.7rem; text-align: right; margin-top: 4px; opacity: 0.7; }
    #typingIndicator { padding: 4px 16px; font-size: 0.8rem; color: #666; font-style: italic; }
</style>

<div id="chatContainer">
    <!-- 联系人列表 -->
    <div id="contactList">
        <h6 class="mb-3">好友列表</h6>
        <div id="friendsList"></div>
    </div>
    <!-- 聊天区域 -->
    <div id="chatArea">
        <div id="chatHeader">👋 请选择好友开始聊天</div>
        <div id="messageList"></div>
        <div id="typingIndicator" style="display:none;"></div>
        <div id="inputArea" style="display:none;">
            <input type="text" id="msgInput" placeholder="输入消息..." onkeydown="if(event.key==='Enter')sendMsg()">
            <button class="btn btn-primary" onclick="sendMsg()">发送</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
// ===== 全局状态 =====
var currentUser = null;
var currentChatUserId = null;
var connection = null;
var friends = [];
var onlineSet = new Set();

// ===== 初始化 =====
(function init() {
    var token = getToken();
    if (!token) { location.href = '/account/login'; return; }

    // 解析JWT payload
    var payload = JSON.parse(atob(token.split('.')[1]));
    currentUser = { id: parseInt(payload.nameid), username: payload.unique_name, nickname: payload.nickname, role: parseInt(payload.role) };

    // 启动SignalR连接
    connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/chat", { accessTokenFactory: () => token })
        .withAutomaticReconnect()
        .build();

    connection.on("ReceivePrivateMessage", onReceiveMessage);
    connection.on("UserOnline", onUserOnline);
    connection.on("UserOffline", onUserOffline);
    connection.on("UserTyping", onUserTyping);
    connection.on("UserStopTyping", onUserStopTyping);

    connection.start().then(loadFriends).catch(e => console.error(e));
})();

function getToken() {
    var c = document.cookie.split('; ').find(r => r.startsWith('AuthToken='));
    return c ? c.split('=')[1] : null;
}

// ===== 好友列表 =====
function loadFriends() {
    fetch('/api/friends', { headers: authHeaders() })
        .then(r => r.json()).then(d => {
            if (d.success) {
                friends = d.data;
                d.data.forEach(f => { if (f.isOnline) onlineSet.add(f.friendUserId); });
                renderFriends();
            }
        });
}

function renderFriends() {
    var html = '';
    friends.forEach(f => {
        var online = onlineSet.has(f.friendUserId);
        html += '<div class="contact-item" onclick="openChat(' + f.friendUserId + ',\'' + f.friendNickname + '\')" data-uid="' + f.friendUserId + '">';
        html += '<span class="dot ' + (online ? 'online' : 'offline') + '"></span>';
        html += '<span>' + f.friendNickname + ' (' + f.friendUsername + ')</span>';
        html += '</div>';
    });
    document.getElementById('friendsList').innerHTML = html || '<p class="text-muted small">暂无好友</p>';
}

// ===== 打开聊天 =====
function openChat(userId, name) {
    currentChatUserId = userId;
    document.getElementById('chatHeader').textContent = '💬 ' + name;
    document.getElementById('inputArea').style.display = 'flex';
    document.getElementById('messageList').innerHTML = '';
    document.querySelectorAll('.contact-item').forEach(el => {
        el.classList.toggle('active', parseInt(el.dataset.uid) === userId);
    });
    loadHistory();
}

function loadHistory() {
    fetch('/api/messages/private/' + currentChatUserId + '?page=1&pageSize=50', { headers: authHeaders() })
        .then(r => r.json()).then(d => {
            if (d.success && d.data) {
                d.data.items.reverse().forEach(msg => appendMessage(msg));
            }
        });
}

// ===== 发送消息 =====
function sendMsg() {
    var input = document.getElementById('msgInput');
    var text = input.value.trim();
    if (!text || !currentChatUserId) return;
    input.value = '';

    connection.invoke("SendPrivateMessage", currentChatUserId, text).catch(err => console.error(err));
    notification('UserStopTyping');
}

// ===== 接收消息 =====
function onReceiveMessage(msg) {
    // 只显示与当前选中好友的聊天
    var relevantId = msg.senderId === currentUser.id ? msg.receiverId : msg.senderId;
    if (currentChatUserId === relevantId) {
        appendMessage(msg);
    } else if (currentChatUserId !== msg.senderId) {
        // TODO: 未读消息提示
    }
}

function appendMessage(msg) {
    var isMine = msg.senderId === currentUser.id;
    var html = '<div class="msg-bubble ' + (isMine ? 'mine' : 'other') + '">';
    if (!isMine) html += '<div class="msg-sender">' + msg.senderNickname + '</div>';
    html += '<div>' + escapeHtml(msg.content) + '</div>';
    html += '<div class="msg-time">' + new Date(msg.sentAt).toLocaleTimeString() + '</div>';
    html += '</div>';
    var container = document.getElementById('messageList');
    container.innerHTML += html;
    container.scrollTop = container.scrollHeight;
}

// ===== 在线状态 =====
function onUserOnline(user) {
    onlineSet.add(user.id);
    renderFriends();
}

function onUserOffline(userId) {
    onlineSet.delete(userId);
    renderFriends();
}

// ===== 打字状态 =====
var typingTimer = null;
document.getElementById('msgInput').addEventListener('input', function() {
    if (!currentChatUserId) return;
    connection.invoke("NotifyTyping", currentChatUserId);
    clearTimeout(typingTimer);
    typingTimer = setTimeout(() => connection.invoke("NotifyStopTyping", currentChatUserId), 2000);
});

function onUserTyping(userId) {
    if (userId === currentChatUserId) {
        var el = document.getElementById('typingIndicator');
        el.textContent = '对方正在输入...';
        el.style.display = 'block';
    }
}

function onUserStopTyping(userId) {
    if (userId === currentChatUserId) {
        document.getElementById('typingIndicator').style.display = 'none';
    }
}

// ===== 工具函数 =====
function authHeaders() {
    return { 'Authorization': 'Bearer ' + getToken(), 'Content-Type': 'application/json' };
}

function escapeHtml(text) {
    var d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
}
</script>
}
