@{
    ViewData["Title"] = "首页";
}

<div class="text-center mt-5">
    <h1 class="display-4 mb-3">💬 网上沟通交流系统</h1>
    <p class="lead">支持桌面端(WPF)和Web端，实时在线聊天</p>
    <hr class="my-4">
    <p id="welcomeMsg">请登录或注册新账号开始使用</p>
    <div class="mt-3" id="actionBtns">
        <a class="btn btn-primary btn-lg me-2" href="/account/login">登录</a>
        <a class="btn btn-outline-primary btn-lg" href="/account/register">注册</a>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var token = document.cookie.split('; ').find(r => r.startsWith('AuthToken='));
    if (token) {
        document.getElementById('welcomeMsg').textContent = '您已登录，开始聊天吧！';
        document.getElementById('actionBtns').innerHTML = '<a class="btn btn-primary btn-lg" href="/chat">进入聊天</a>';
    }
})();
</script>
}
