<Window x:Class="ChatSystem.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ChatSystem.Wpf.Converters"
        Title="💬 ChatSystem" Height="650" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:OnlineStatusToColorConverter x:Key="OnlineColor"/>
        <converters:MessageAlignmentConverter x:Key="MsgAlign"/>
        <converters:MessageBackgroundConverter x:Key="MsgBg"/>
        <converters:MessageForegroundConverter x:Key="MsgFg"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 侧边栏 ===== -->
        <Border Grid.Column="0" Background="#212529">
            <StackPanel>
                <!-- 用户信息 -->
                <StackPanel Margin="16,16,16,8">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="Bold"
                               Text="{Binding UserDisplayName}"/>
                    <TextBlock Foreground="#ADB5BD" FontSize="12"
                               Text="{Binding UserRoleText}"/>
                </StackPanel>
                <Separator Background="#495057" Margin="8,0"/>

                <!-- 导航按钮 -->
                <Button Content="💬 聊天" Style="{StaticResource SidebarBtn}"
                        Command="{Binding NavigateCommand}" CommandParameter="chat"/>
                <Button Content="👥 好友管理" Style="{StaticResource SidebarBtn}"
                        Command="{Binding NavigateCommand}" CommandParameter="friends"/>
                <Button Content="📩 好友申请" Style="{StaticResource SidebarBtn}"
                        Command="{Binding NavigateCommand}" CommandParameter="requests"/>
                <Button Content="📋 聊天记录" Style="{StaticResource SidebarBtn}"
                        Command="{Binding NavigateCommand}" CommandParameter="history"/>

                <!-- 管理员按钮 -->
                <Button Content="🛡️ 管理员面板" Style="{StaticResource SidebarBtn}"
                        Command="{Binding NavigateCommand}" CommandParameter="admin"
                        Visibility="{Binding ShowAdmin, Converter={StaticResource BoolToVis}}"/>

                <Separator Background="#495057" Margin="8,16,8,8"/>

                <Button Content="🚪 退出登录" Style="{StaticResource SidebarBtn}"
                        Command="{Binding LogoutCommand}" Foreground="#FF6B6B"/>
            </StackPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Border Grid.Column="1" Background="#F8F9FA">
            <Grid>
                <!-- 聊天页面 -->
                <Grid Visibility="{Binding IsChatPage, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 好友列表 -->
                    <Border Grid.Column="0" BorderBrush="#DEE2E6" BorderThickness="0,0,1,0" Background="White">
                        <StackPanel>
                            <TextBlock Text="好友列表" FontWeight="Bold" Padding="12,12,12,8"
                                       Background="#F1F3F5"/>
                            <ListBox ItemsSource="{Binding Friends}" SelectedItem="{Binding SelectedFriend}"
                                     BorderThickness="0" Margin="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,6">
                                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                     Fill="{Binding IsOnline, Converter={StaticResource OnlineColor}}"/>
                                            <TextBlock Text="{Binding FriendNickname}" FontSize="14"/>
                                            <TextBlock Text="●" Foreground="Red" FontSize="10" Margin="4,0,0,0"
                                                       Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- 聊天区域 -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 聊天标题 -->
                        <Border Grid.Row="0" Background="#F1F3F5" Padding="12,10"
                                BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
                            <TextBlock FontWeight="Bold" FontSize="14">
                                <Run Text="💬 "/>
                                <Run Text="{Binding SelectedFriend.FriendNickname, FallbackValue='请选择好友'}"/>
                            </TextBlock>
                        </Border>

                        <!-- 消息列表 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Messages}" Margin="12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,4" CornerRadius="10"
                                                Background="{Binding IsMine, Converter={StaticResource MsgBg}}"
                                                HorizontalAlignment="{Binding IsMine, Converter={StaticResource MsgAlign}}"
                                                MaxWidth="300">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SenderNickname}" FontSize="11"
                                                           Foreground="{Binding IsMine, Converter={StaticResource MsgFg}}"
                                                           Visibility="{Binding IsMine, Converter={StaticResource InverseBool}}"/>
                                                <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                           Foreground="{Binding IsMine, Converter={StaticResource MsgFg}}"/>
                                                <TextBlock Text="{Binding SentAt}" FontSize="10"
                                                           Foreground="{Binding IsMine, Converter={StaticResource MsgFg}}"
                                                           HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 输入区 -->
                        <Border Grid.Row="2" Background="White" Padding="10"
                                BorderBrush="#DEE2E6" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" VerticalAlignment="Center"
                                         IsEnabled="{Binding SelectedFriend, Converter={StaticResource BoolToVis}}"/>
                                <Button Grid.Column="1" Content="发送" Margin="8,0,0,0"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding SendMessageCommand}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 好友管理页面 -->
                <Grid Visibility="{Binding IsFriendsPage, Converter={StaticResource BoolToVis}}" Margin="16">
                    <StackPanel>
                        <TextBlock Text="添加好友" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="搜索" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding SearchUsersCommand}"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding SearchResults}" Margin="0,8" MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nickname}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Username}" Foreground="Gray"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="添加好友"
                                                Command="{Binding DataContext.AddFriendCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding Id}" Padding="8,3"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="我的好友" FontWeight="Bold" FontSize="14" Margin="0,16,0,8"/>
                        <ItemsControl ItemsSource="{Binding Friends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="0,2" Background="White" CornerRadius="6">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                         Fill="{Binding IsOnline, Converter={StaticResource OnlineColor}}"/>
                                                <TextBlock Text="{Binding FriendNickname}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Content="删除" Foreground="Red"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveFriendCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding FriendUserId}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- 好友申请页面 -->
                <Grid Visibility="{Binding IsRequestsPage, Converter={StaticResource BoolToVis}}" Margin="16">
                    <StackPanel>
                        <TextBlock Text="收到的好友申请" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding PendingRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,4" Background="White" CornerRadius="6">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock FontWeight="Bold" Text="{Binding FromNickname}"/>
                                                <TextBlock Text="{Binding FromUsername}" Foreground="Gray"/>
                                                <TextBlock Text="{Binding SentAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                           FontSize="11" Foreground="Gray"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="同意" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"
                                                        Command="{Binding DataContext.AcceptRequestCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}"/>
                                                <Button Content="拒绝"
                                                        Command="{Binding DataContext.RejectRequestCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}" Padding="12,8"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="暂无待处理的申请" Foreground="Gray" Margin="0,8"
                                   Visibility="{Binding PendingRequests.Count, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                    </StackPanel>
                </Grid>

                <!-- 管理员面板 -->
                <Grid Visibility="{Binding IsAdminPage, Converter={StaticResource BoolToVis}}" Margin="16">
                    <ContentPresenter>
                        <!-- Admin content handled in page -->
                    </ContentPresenter>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
